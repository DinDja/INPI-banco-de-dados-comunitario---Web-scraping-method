# Ignore everything by default
*
!.gitignore
!package.json
!README.md

# Include API directory and all its contents
!api/
!api/**

# Include data directory but only specific files
!data/
!data/patentes.jsonl
!data/patentes.part*.jsonl
!data/programas.jsonl
!data/programas.part*.jsonl

# Node modules (keep ignored even with wildcard exception)
node_modules/
npm-debug.log
package-lock.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local

# Temporary files
*.tmp
.cache/


